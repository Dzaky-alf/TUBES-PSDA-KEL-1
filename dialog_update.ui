  <property name="styleSheet">
   <string notr="true">/* 1. BACKGROUND JENDELA */
QDialog {
    background-color: #ffffff; /* Putih bersih */
}

/* 2. JUDUL (Pastikan objectName-nya: label_judul) */
QLabel#label_judulstok {
    font-size: 20pt;
    font-weight: bold;
    color: #1f2937;
    margin-bottom: 15px;
    background: transparent;
}

/* 3. LABEL KETERANGAN (Nama Barang, SKU, dll) */
QLabel {
    font-size: 10pt;
    font-weight: bold;
    color: #4b5563; /* Abu-abu gelap elegan */
    background: transparent;
}

/* 4. KOTAK INPUT (LineEdit &amp; SpinBox) */
QLineEdit, QSpinBox {
    border: 1px solid #d1d5db;
    border-radius: 8px; /* Membuat sudut melengkung */
    padding: 10px;
    background-color: #f9fafb;
    color: #1f2937;
    font-size: 10pt;
}

/* Efek saat kotak input diklik */
QLineEdit:focus, QSpinBox:focus {
    border: 2px solid #2563eb; /* Garis biru tebal */
    background-color: #ffffff;
}

/* 5. TOMBOL TAMBAH (Pastikan objectName-nya: btn_simpan) */
QPushButton#btn_simpan_update {
    background-color: #2563eb; /* Biru Modern */
    color: white;
    border: none;
    border-radius: 8px;
    padding: 12px;
    font-weight: bold;
    font-size: 11pt;
}

QPushButton#btn_simpan_update:hover {
    background-color: #1d4ed8; /* Biru lebih gelap saat disentuh */
}

/* 6. TOMBOL BATAL (Pastikan objectName-nya: btn_batal) */
QPushButton#btn_batal_update {
    background-color: white;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 12px;
    font-weight: bold;
    font-size: 11pt;
}

QPushButton#btn_batal_update:hover {
    background-color: #f3f4f6;
}</string>
